# =====================================================
# Configuração do BemCicatri Backend
# =====================================================

# Porta do servidor
PORT=3000

# Banco de dados PostgreSQL
# O banco e as tabelas necessárias são criados automaticamente quando o servidor inicia,
# desde que o PostgreSQL esteja disponível com as credenciais corretas.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=bemcicatri
DB_SSL=false

# Configuração de Email (opcional)
# Para envio de e-mail real, preencha com os dados do seu servidor SMTP.
# Exemplo Gmail: host=smtp.gmail.com, port=587, secure=false.
# Se usar Gmail, gere uma senha de app e não use a senha normal da conta.
# SMTP_HOST=
# SMTP_PORT=
# SMTP_SECURE=
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=""
# APP_BASE_URL=http://localhost:3000

# Configuração de API
API_URL=http://localhost:3000
NODE_ENV=development
